# Applied as ONE atomic `nft -f` transaction so the catch-all drop is never absent.
# Identical to the legacy DOCKER-USER iptables rules; nft is the backend on these hosts.
flush chain ip filter DOCKER-USER
add rule ip filter DOCKER-USER ct state invalid drop
add rule ip filter DOCKER-USER ct state established,related return
add rule ip filter DOCKER-USER iifname "br*" return
add rule ip filter DOCKER-USER iifname "lo" oifname "br*" return
add rule ip filter DOCKER-USER drop
flush chain ip6 filter DOCKER-USER
add rule ip6 filter DOCKER-USER ct state invalid drop
add rule ip6 filter DOCKER-USER ct state established,related return
add rule ip6 filter DOCKER-USER iifname "br*" return
add rule ip6 filter DOCKER-USER iifname "lo" oifname "br*" return
add rule ip6 filter DOCKER-USER drop
