# Installed by the miuops firewall role (drop-in for docker.service). Fail-closed coupling:
# Docker must NOT start unless the host firewall applied successfully. Without this, a
# failed firewall apply at boot would let Docker start with DOCKER-USER at its permissive
# default RETURN, exposing published container ports to the internet. Requires (not Wants)
# blocks Docker on a firewall failure; After ensures Docker starts only once the firewall
# unit has finished. Trade-off: a firewall failure takes Docker (and its containers) down
# -- intentional, since exposing container ports is worse than the services being offline.
[Unit]
Requires=miuops-firewall-host.service
After=miuops-firewall-host.service

[Service]
# Re-validate + re-apply the host firewall on EVERY Docker (re)start. host.service is
# RemainAfterExit (stays "active" after its first success), so Requires= alone only proves
# the firewall applied ONCE -- not that it is still correct. This ExecStartPre re-runs the
# applier before dockerd on each start; if the firewall can't be applied, Docker does not
# start (fail-closed on every start), and any host-firewall drift is corrected at restart.
ExecStartPre=/usr/local/sbin/miuops-firewall.sh host
