#!/usr/bin/env bash
# miuops firewall applier — manages ONLY host-owned chains (INPUT, OUTPUT/FORWARD
# policy, DOCKER-USER contents). It never flushes or edits Docker's chains.
# Rendered by the firewall role; no Jinja variables (kept static on purpose).
# Usage: miuops-firewall.sh <host|docker-user>
set -euo pipefail

RULES_DIR=/etc/miuops-firewall

# Serialize invocations: the reconcile timer, the PartOf=docker unit, and a converge
# can all run this concurrently. Without a lock they race on DOCKER-USER and can leave
# it empty/half-applied. The bounded `-w 30` on each iptables call additionally
# coordinates with Docker's own iptables ops on the kernel xtables lock, bounded so a
# stuck lock fails closed+loud rather than hanging.
exec 9>/run/miuops-firewall.lock
flock -w 30 9 || { echo "FATAL: could not acquire /run/miuops-firewall.lock within 30s" >&2; exit 1; }

# Detect IPv6 usability once. On a v4-only host (ipv6.disable=1 / no ip6_tables module)
# ip6tables errors; skip all v6 work gracefully instead of aborting under `set -e`.
HAVE_V6=1
ip6tables -w 30 -S >/dev/null 2>&1 || HAVE_V6=0

assert_forward_jump() {
  # $1 = iptables|ip6tables. The FORWARD->DOCKER-USER jump is Docker-owned. A PERSISTENT
  # absence/misorder means Docker's chains are corrupt (the shared-prod class) -> fail
  # loudly. A Docker (re)start briefly tears the jump down and rebuilds it, so RETRY up
  # to ~30s first (matches CI's repopulation budget) to avoid flapping `failed` on a
  # transient absence. Callers only invoke this when Docker is active.
  local ipt="$1" fwd ln_user ln_fwd
  for _ in {1..30}; do
    fwd="$("$ipt" -w 30 -S FORWARD)"
    if grep -q -- '-A FORWARD -j DOCKER-USER' <<<"$fwd"; then
      ln_user="$(grep -n -- '-A FORWARD -j DOCKER-USER'    <<<"$fwd" | head -1 | cut -d: -f1 || true)"
      ln_fwd="$( grep -n -- '-A FORWARD -j DOCKER-FORWARD' <<<"$fwd" | head -1 | cut -d: -f1 || true)"
      # OK if DOCKER-FORWARD absent, or DOCKER-USER precedes it.
      if [ -z "$ln_fwd" ] || [ "$ln_user" -lt "$ln_fwd" ]; then
        return 0
      fi
    fi
    sleep 1
  done
  echo "FATAL: $ipt FORWARD jump to DOCKER-USER missing/misordered after retries -- Docker chains corrupt." >&2
  echo "       Repair: systemctl restart docker" >&2
  return 1
}

apply_host() {
  # Fail-closed FIRST: set default policies DROP before touching any rules, so any later
  # failure leaves the host CLOSED, never open.
  iptables  -w 30 -P INPUT DROP;  iptables  -w 30 -P FORWARD DROP;  iptables  -w 30 -P OUTPUT ACCEPT
  if [ "$HAVE_V6" = 1 ]; then
    ip6tables -w 30 -P INPUT DROP;  ip6tables -w 30 -P FORWARD DROP;  ip6tables -w 30 -P OUTPUT ACCEPT
  fi
  # Replace INPUT only. The explicit -F is REQUIRED: a built-in chain is NOT flushed by
  # its ":INPUT DROP" line under --noflush (unlike a user chain like DOCKER-USER --
  # verified on-host), so without -F the rules would duplicate. Policy stays DROP across
  # the -F->restore gap -> fail-closed; --noflush leaves OUTPUT/FORWARD/Docker chains alone.
  iptables-restore --wait 30 --test --noflush "$RULES_DIR/host.v4.rules"
  iptables  -w 30 -F INPUT;  iptables-restore  --wait 30 --noflush "$RULES_DIR/host.v4.rules"
  if [ "$HAVE_V6" = 1 ]; then
    ip6tables-restore --wait 30 --test --noflush "$RULES_DIR/host.v6.rules"
    ip6tables -w 30 -F INPUT;  ip6tables-restore --wait 30 --noflush "$RULES_DIR/host.v6.rules"
  fi
  # Seed DOCKER-USER now too: host.service runs BEFORE docker, so the container catch-all
  # DROP is already in place when Docker starts + republishes ports at boot -- closing the
  # brief per-reboot window. docker-user.service refreshes it + asserts the jump after Docker.
  ensure_docker_user
}

reconcile_docker_user() {
  # $1 = iptables|ip6tables, $2 = rules file. Idempotent: skip if already exactly our
  # ruleset (so the steady state + reconcile timer do no work and reset no counters).
  # The file's ":DOCKER-USER -" line makes a single `restore --noflush` atomically FLUSH +
  # repopulate this USER chain in ONE transaction (verified) -- so the catch-all DROP is
  # never momentarily absent. (No explicit -F: that would split it into two transactions
  # and open an empty-chain fail-open window. NB: declare-flush works for USER chains only;
  # built-in chains like INPUT must use -F -- see apply_host.) Uses iptables-restore (NOT
  # raw nft) so the table stays readable by iptables + Docker.
  # NB: the skip-compare assumes `iptables -S` renders these matches byte-identically to
  # the file; do NOT add -p tcp/--dport/recent-style matches to docker-user.rules without
  # re-verifying (else it re-applies each tick -- still atomic + safe, only resets counters).
  local ipt="$1" file="$2" current desired
  desired="$(grep '^-A DOCKER-USER' "$file")"
  current="$("$ipt" -w 30 -S DOCKER-USER 2>/dev/null | grep '^-A DOCKER-USER' || true)"
  [ "$current" = "$desired" ] && return 0
  "$ipt"-restore --wait 30 --test --noflush "$file"   # validate the exact file we apply
  "$ipt"-restore --wait 30 --noflush "$file"          # :DOCKER-USER - flush + reload, one atomic txn
}

ensure_docker_user() {
  # Seed/reconcile DOCKER-USER (both families). No jump assert here, so it is safe to call
  # from apply_host BEFORE Docker exists/starts (seeds the catch-all DROP so it is live the
  # instant Docker adds the FORWARD->DOCKER-USER jump). Docker's create-if-absent leaves
  # our existing chain intact.
  iptables  -w 30 -N DOCKER-USER 2>/dev/null || true
  reconcile_docker_user iptables  "$RULES_DIR/docker-user.rules"
  if [ "$HAVE_V6" = 1 ]; then
    ip6tables -w 30 -N DOCKER-USER 2>/dev/null || true
    reconcile_docker_user ip6tables "$RULES_DIR/docker-user.rules"
  fi
}

apply_docker_user() {
  ensure_docker_user
  # Only assert the Docker-owned FORWARD jump when Docker is actually running: the timer
  # (and the converge handler) can fire while Docker is stopped (maintenance) or not yet
  # installed (first boot), where an absent jump is expected -- not corruption.
  if systemctl is-active --quiet docker; then
    assert_forward_jump iptables
    if [ "$HAVE_V6" = 1 ]; then assert_forward_jump ip6tables; fi
  fi
}

case "${1:-}" in
  host)        apply_host ;;
  docker-user) apply_docker_user ;;
  *) echo "usage: miuops-firewall.sh <host|docker-user>" >&2; exit 2 ;;
esac
