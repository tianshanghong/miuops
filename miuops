#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="${MIUOPS_TEST_SCRIPT_DIR:-$(cd "$(dirname "$0")" && pwd)}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'

die()  { echo -e "${RED}error:${NC} $1" >&2; exit 1; }
info() { echo -e "${GREEN}=>${NC} $1"; }
warn() { echo -e "${YELLOW}=>${NC} $1"; }
dry()  { echo -e "  ${YELLOW}[dry-run]${NC} $1"; }

DRY_RUN=false
NO_APPLY=false

# ── Validation ──────────────────────────────────────────────────────
valid_domain() { echo "$1" | grep -qE '^[a-zA-Z0-9]([a-zA-Z0-9.-]*[a-zA-Z0-9])?\.[a-zA-Z]{2,}$'; }
# A host alias becomes a filename (host_vars/<h>.yml) and an inventory key, so
# restrict it to a safe charset — blocks path traversal and sed/grep metachars.
valid_host_alias() { echo "$1" | grep -qE '^[A-Za-z0-9._-]+$'; }

# ── Config helpers (host_vars + inventory) ──────────────────────────
hv_path() { echo "${SCRIPT_DIR}/host_vars/$1.yml"; }

hv_domains() {
    local f; f="$(hv_path "$1")"; [[ -f "$f" ]] || return 0
    sed -n 's/^[[:space:]]*-[[:space:]][[:space:]]*"\{0,1\}\([^"]*\)"\{0,1\}.*/\1/p' "$f"
}

hv_tunnel() {
    local f; f="$(hv_path "$1")"; [[ -f "$f" ]] || return 0
    sed -n 's/^tunnel_id:[[:space:]]*"\{0,1\}\([^"]*\)"\{0,1\}.*/\1/p' "$f" | head -1
}

write_host_vars() {
    local host="$1" tid="$2"; shift 2
    local f; f="$(hv_path "$host")"; mkdir -p "$(dirname "$f")"
    { echo "---"; echo "domains:";
      local d; for d in "$@"; do echo "  - \"${d}\""; done
      echo ""; echo "tunnel_id: \"${tid}\""; } > "$f"
}

inventory_upsert() {
    local host="$1" ah="$2" au="$3" inv="${SCRIPT_DIR}/inventory.ini"
    local line="${host} ansible_host=${ah} ansible_user=${au}"
    if [[ -f "$inv" ]] && grep -qE "^${host}[[:space:]]" "$inv"; then
        local tmp; tmp="$(mktemp)"
        sed "s|^${host}[[:space:]].*|${line}|" "$inv" > "$tmp" && mv "$tmp" "$inv"
    else
        [[ -f "$inv" ]] || printf '[bare_metal]\n' > "$inv"
        grep -q '^\[bare_metal\]' "$inv" || printf '[bare_metal]\n' >> "$inv"
        printf '%s\n' "$line" >> "$inv"
    fi
}

# Echoes the inventory host that already owns <domain> (empty if none).
domain_owner() {
    local domain="$1" f host
    for f in "${SCRIPT_DIR}"/host_vars/*.yml; do
        [[ -e "$f" ]] || continue
        host="$(basename "$f" .yml)"
        if hv_domains "$host" | grep -qx "$domain"; then echo "$host"; return 0; fi
    done
}

# ── Cloudflare DNS helpers ─────────────────────────────────────────
cf_zone_id() {
    local domain="$1" resp http
    resp=$(curl -s -w "\n%{http_code}" \
        "https://api.cloudflare.com/client/v4/zones?name=${domain}" \
        -H "Authorization: Bearer ${CF_API_TOKEN}" -H "Content-Type: application/json") \
        || die "Cloudflare API request failed — network error"
    http=$(echo "$resp" | tail -1); resp=$(echo "$resp" | sed '$d')
    case "$http" in
        200) ;;
        401|403) die "Cloudflare API returned ${http} (unauthorized)
  - Is your CF_API_TOKEN valid?
  - Does it have Zone:Read and DNS:Edit permissions?" ;;
        *) die "Cloudflare API returned HTTP ${http} for zone '${domain}'
  Response: $(echo "$resp" | jq -r '.errors[0].message // empty' 2>/dev/null || echo 'unknown')" ;;
    esac
    local zid; zid=$(echo "$resp" | jq -r '.result[0].id // empty')
    [[ -n "$zid" ]] || die "Zone not found for '${domain}'
  - Is the domain added to your Cloudflare account?
  - Does your API token have access to this zone?"
    echo "$zid"
}

cf_create_cname() {
    local zid="$1" name="$2" tid="$3"
    if $DRY_RUN; then dry "Would create CNAME ${name} -> ${tid}.cfargotunnel.com"; return 0; fi
    local resp ok msg
    resp=$(curl -s -X POST \
        "https://api.cloudflare.com/client/v4/zones/${zid}/dns_records" \
        -H "Authorization: Bearer ${CF_API_TOKEN}" -H "Content-Type: application/json" \
        --data "{\"type\":\"CNAME\",\"name\":\"${name}\",\"content\":\"${tid}.cfargotunnel.com\",\"proxied\":true}") \
        || die "Cloudflare API request failed — network error"
    ok=$(echo "$resp" | jq -r '.success')
    if [[ "$ok" == "true" ]]; then
        info "DNS record created for ${name}"
    else
        msg=$(echo "$resp" | jq -r '.errors[0].message // empty' 2>/dev/null)
        if echo "$msg" | grep -qi "already exists"; then
            info "DNS record for ${name} already exists (OK)"
        else
            warn "Failed to create DNS record for ${name}: ${msg:-unknown error}"
        fi
    fi
}

cf_delete_cname() {
    local zid="$1" name="$2" rid
    rid=$(curl -s "https://api.cloudflare.com/client/v4/zones/${zid}/dns_records?type=CNAME&name=${name}" \
        -H "Authorization: Bearer ${CF_API_TOKEN}" | jq -r '.result[0].id // empty')
    [[ -n "$rid" ]] || { info "CNAME ${name} already absent (OK)"; return 0; }
    if $DRY_RUN; then dry "Would delete CNAME ${name}"; return 0; fi
    curl -s -X DELETE "https://api.cloudflare.com/client/v4/zones/${zid}/dns_records/${rid}" \
        -H "Authorization: Bearer ${CF_API_TOKEN}" >/dev/null && info "Deleted CNAME ${name}"
}

# Converge: run the playbook (optionally limited to one host). Honors DRY_RUN/NO_APPLY.
run_apply() {
    local host="${1:-}"
    if $NO_APPLY; then info "--no-apply: skipping converge"; return 0; fi
    local cmd=(ansible-playbook "${SCRIPT_DIR}/playbook.yml")
    [[ -n "$host" ]] && cmd+=(--limit "$host")
    if $DRY_RUN; then dry "Would run: ${cmd[*]}"; return 0; fi
    info "Converging${host:+ ${host}}..."
    "${cmd[@]}"
}

cmd_apply() {
    local host=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)  DRY_RUN=true; shift ;;
            --no-apply) NO_APPLY=true; shift ;;
            -*) die "Unknown flag: $1" ;;
            *)  host="$1"; shift ;;
        esac
    done
    run_apply "$host"
}

usage() {
    cat <<EOF
miuops — provision & manage a fleet of Docker + Traefik + Cloudflare-Tunnel servers.

Usage:
  ./miuops up [--dry-run] [--no-apply] <user@host> <domain> [domain ...]
      Day-1: register the host, create its tunnel + DNS, write host_vars, converge.
      Additive — re-running adds domains, never drops them.

  ./miuops apply [--dry-run] [--no-apply] [<host>]
      Day-2: converge one host (or the whole fleet if <host> is omitted).

  ./miuops add-domain [--dry-run] [--no-apply] <host> <domain> [domain ...]
      Add domain(s) to an existing host (creates DNS, merges into host_vars).

  ./miuops remove-domain [--dry-run] [--no-apply] [--force] <host> <domain> [domain ...]
      Remove domain(s) from a host and delete their Cloudflare CNAMEs.

Options:
  --dry-run     Show what would happen without making changes
  --no-apply    Change config/DNS but skip the Ansible converge

Environment:
  CF_API_TOKEN  Cloudflare API token ('Edit zone DNS' template); needed by
                up/add-domain/remove-domain (not by apply).

Examples:
  CF_API_TOKEN=xxx ./miuops up root@203.0.113.10 example.com
  CF_API_TOKEN=xxx ./miuops add-domain 203.0.113.10 example.org
  ./miuops apply                 # converge the whole fleet
  ./miuops apply 203.0.113.10    # converge one server
EOF
    exit 1
}

cmd_up() {
    # Parse flags and positional args in any order
    local positional=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) DRY_RUN=true; shift ;;
            --no-apply) NO_APPLY=true; shift ;;
            -*) die "Unknown flag: $1" ;;
            *) positional+=("$1"); shift ;;
        esac
    done

    [[ ${#positional[@]} -ge 2 ]] || usage

    local target="${positional[0]}"
    local domains=("${positional[@]:1}")
    local domain
    local ssh_user ssh_host
    local zone_id_list=()

    # Parse user@host
    if [[ "$target" == *@* ]]; then
        ssh_user="${target%%@*}"
        ssh_host="${target#*@}"
    else
        ssh_user="root"
        ssh_host="$target"
    fi

    # The host becomes a filename + inventory key — keep it to a safe charset.
    valid_host_alias "$ssh_host" || die "Invalid host '${ssh_host}'
  Use letters, digits, dot, dash, underscore (IPv6 literals need a named alias)."

    # Validate domain format (portable — no bash regex quantifiers)
    for domain in "${domains[@]}"; do
        valid_domain "$domain" || die "Invalid domain: '${domain}'
  Expected format: example.com"
    done

    # A domain belongs to exactly one server (its CNAMEs point to one tunnel).
    for domain in "${domains[@]}"; do
        local owner; owner="$(domain_owner "$domain")"
        if [[ -n "$owner" && "$owner" != "$ssh_host" ]]; then
            die "Domain '${domain}' already belongs to server '${owner}'.
  A domain maps to exactly one server. Run 'remove-domain ${owner} ${domain}' first."
        fi
    done

    [[ -n "${CF_API_TOKEN:-}" ]] || die "CF_API_TOKEN is required
  1. Go to https://dash.cloudflare.com/profile/api-tokens
  2. Click 'Create Token'
  3. Use the 'Edit zone DNS' template
  4. Select your zone, then create
  Then run: CF_API_TOKEN=your_token ./miuops up ..."

    # ── Step 1: Prerequisites ──────────────────────────────────────
    info "Checking prerequisites..."

    local prereqs_ok=true

    command -v curl >/dev/null 2>&1 \
        || die "curl not found
  macOS:  curl is pre-installed
  Linux:  sudo apt install curl"
    command -v ssh >/dev/null 2>&1 \
        || die "ssh not found
  macOS:  ssh is pre-installed
  Linux:  sudo apt install openssh-client"
    command -v ansible-playbook >/dev/null 2>&1 \
        || die "ansible not found
  macOS:  brew install ansible
  Linux:  sudo apt install ansible"
    command -v cloudflared >/dev/null 2>&1 \
        || die "cloudflared not found
  macOS:  brew install cloudflare/cloudflare/cloudflared
  Linux:  See https://pkg.cloudflare.com/"
    command -v jq >/dev/null 2>&1 \
        || die "jq not found
  macOS:  brew install jq
  Linux:  sudo apt install jq"

    if ! ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=no \
         "${ssh_user}@${ssh_host}" true 2>/dev/null; then
        if $DRY_RUN; then
            warn "Cannot SSH to ${ssh_user}@${ssh_host} — would need to be reachable"
            prereqs_ok=false
        else
            die "Cannot SSH to ${ssh_user}@${ssh_host}
  - Is the IP/hostname correct?
  - Is your SSH key added? (ssh-add -l)
  - Is the server accepting connections on port 22?"
        fi
    fi

    if $prereqs_ok; then
        info "Prerequisites OK"
    else
        info "Prerequisites OK (with warnings)"
    fi

    # ── Step 2: Look up Zone IDs ────────────────────────────────────
    local zone_id
    for domain in "${domains[@]}"; do
        info "Looking up Zone ID for ${domain}..."
        zone_id="$(cf_zone_id "$domain")"
        zone_id_list+=("$zone_id")
        info "Zone ID: ${zone_id}"
    done

    # ── Step 3: Create or reuse Cloudflare Tunnel ──────────────────
    # Replace chars unsafe for tunnel names (dots, colons in IPv6, slashes)
    local tunnel_name="miuops-${ssh_host//[:.\/]/-}"
    local tunnel_id=""

    # Reuse this host's existing tunnel from host_vars (additive — never drops domains)
    local existing_tid
    existing_tid="$(hv_tunnel "$ssh_host")"
    if [[ -n "$existing_tid" && "$existing_tid" != "<would-be-created>" ]]; then
        tunnel_id="$existing_tid"
        info "Reusing tunnel ID from host_vars: ${tunnel_id}"
    fi

    # merged_domains = union(existing host_vars domains, passed domains). DNS is
    # created only for the passed domains (Step 4); host_vars stores the union so a
    # re-run that passes fewer domains never silently drops the others.
    local merged_domains=() md
    while IFS= read -r md; do [[ -n "$md" ]] && merged_domains+=("$md"); done < <(hv_domains "$ssh_host")
    for domain in "${domains[@]}"; do
        local present=false m
        for m in "${merged_domains[@]:-}"; do [[ "$m" == "$domain" ]] && present=true; done
        $present || merged_domains+=("$domain")
    done

    if [[ ! -f ~/.cloudflared/cert.pem ]]; then
        if $DRY_RUN; then
            warn "Cloudflare login would be required (no cert.pem found)"
        else
            warn "Cloudflare login required..."
            cloudflared login
        fi
    fi

    # Validate cert by listing tunnels; re-login if stale
    local existing
    if [[ -f ~/.cloudflared/cert.pem ]]; then
        existing=$(cloudflared tunnel list -o json 2>&1) || true
        if ! echo "$existing" | jq -e 'type == "array"' >/dev/null 2>&1; then
            if $DRY_RUN; then
                warn "Cloudflare cert.pem appears stale — would need to re-login"
                existing="[]"
            else
                warn "Cloudflare cert.pem is stale, re-authenticating..."
                rm -f ~/.cloudflared/cert.pem
                cloudflared login
                existing=$(cloudflared tunnel list -o json 2>/dev/null || echo "[]")
            fi
        fi
    else
        existing="[]"
    fi

    # Verify tunnel from config still exists in Cloudflare
    if [[ -n "$tunnel_id" ]]; then
        local tid_exists
        tid_exists=$(echo "$existing" | jq -r --arg id "$tunnel_id" \
            '.[] | select(.id == $id and (.deleted_at == null or .deleted_at == "" or .deleted_at == "0001-01-01T00:00:00Z")) | .id' \
            2>/dev/null | head -1) || true
        if [[ -z "$tid_exists" ]]; then
            warn "Tunnel ${tunnel_id} from config no longer exists in Cloudflare — will search or create"
            tunnel_id=""
        fi
    fi

    # Search by name if no tunnel_id yet
    if [[ -z "$tunnel_id" ]]; then
        info "Checking for existing tunnel '${tunnel_name}'..."
        tunnel_id=$(echo "$existing" | jq -r --arg name "$tunnel_name" \
            '.[] | select(.name == $name and (.deleted_at == null or .deleted_at == "" or .deleted_at == "0001-01-01T00:00:00Z")) | .id' \
            2>/dev/null | head -1) || true
    fi

    if [[ -n "$tunnel_id" ]]; then
        info "Reusing existing tunnel: ${tunnel_id}"
    elif $DRY_RUN; then
        tunnel_id="<would-be-created>"
        dry "Would create tunnel '${tunnel_name}'"
    else
        info "Creating tunnel '${tunnel_name}'..."
        local tunnel_output
        tunnel_output=$(cloudflared tunnel create "${tunnel_name}" 2>&1) || true
        tunnel_id=$(echo "$tunnel_output" | \
            grep -o '[a-f0-9]\{8\}-[a-f0-9]\{4\}-[a-f0-9]\{4\}-[a-f0-9]\{4\}-[a-f0-9]\{12\}' | head -1) || true

        if [[ -n "$tunnel_id" ]]; then
            info "Created tunnel: ${tunnel_id}"
        else
            # Creation failed (likely "already exists") — try to find it
            warn "Tunnel creation returned no ID: ${tunnel_output}"
            local retry
            retry=$(cloudflared tunnel list -o json 2>/dev/null || echo "[]")
            tunnel_id=$(echo "$retry" | jq -r --arg name "$tunnel_name" \
                '.[] | select(.name == $name and (.deleted_at == null or .deleted_at == "" or .deleted_at == "0001-01-01T00:00:00Z")) | .id' \
                2>/dev/null | head -1) || true
            [[ -n "$tunnel_id" ]] || die "Failed to create or find tunnel '${tunnel_name}'
  - Is cloudflared logged in? (cloudflared login)
  - Run 'cloudflared tunnel list' to check"
            info "Found existing tunnel: ${tunnel_id}"
        fi
    fi

    # Copy credentials
    if ! $DRY_RUN; then
        mkdir -p "${SCRIPT_DIR}/files"
        if [[ ! -f "${SCRIPT_DIR}/files/${tunnel_id}.json" ]]; then
            if [[ -f ~/.cloudflared/${tunnel_id}.json ]]; then
                cp ~/.cloudflared/"${tunnel_id}.json" "${SCRIPT_DIR}/files/"
                info "Tunnel credentials copied"
            else
                die "Credentials not found at ~/.cloudflared/${tunnel_id}.json
  - Did 'cloudflared tunnel create' succeed?
  - Check ~/.cloudflared/ for JSON files"
            fi
        fi
    else
        dry "Would copy tunnel credentials to files/"
    fi

    # ── Step 4: Create DNS records ───────────────────────────────────
    info "Creating DNS records..."

    local i zid
    for i in "${!domains[@]}"; do
        domain="${domains[$i]}"
        zid="${zone_id_list[$i]}"
        cf_create_cname "$zid" "${domain}" "$tunnel_id"
        cf_create_cname "$zid" "*.${domain}" "$tunnel_id"
    done

    # ── Step 5: Write config + converge ────────────────────────────
    if $DRY_RUN; then
        info "Would write host_vars/${ssh_host}.yml:"
        echo "domains:"; printf '  - "%s"\n' "${merged_domains[@]}"
        echo "tunnel_id: \"${tunnel_id}\""
        info "Would upsert inventory.ini host '${ssh_host}' (ansible_user=${ssh_user})"
        dry "Would install Ansible Galaxy requirements"
        dry "Would run: ansible-playbook playbook.yml --limit ${ssh_host}"
        echo ""
        info "${BOLD}Dry run complete.${NC} Re-run without --dry-run to execute."
    else
        info "Writing host_vars/${ssh_host}.yml..."
        write_host_vars "$ssh_host" "$tunnel_id" "${merged_domains[@]}"

        info "Updating inventory.ini..."
        inventory_upsert "$ssh_host" "$ssh_host" "$ssh_user"

        info "Installing Ansible Galaxy requirements..."
        if ! ansible-galaxy collection install -r "${SCRIPT_DIR}/requirements.yml" 2>&1; then
            die "Failed to install Ansible Galaxy requirements"
        fi

        run_apply "$ssh_host"

        echo ""
        info "${BOLD}Done!${NC} Server bootstrapped."
        info "Tunnel: ${tunnel_id}"
        for domain in "${merged_domains[@]}"; do
            info "Domain: *.${domain} -> Cloudflare Tunnel -> Traefik"
        done
        echo ""
        info "Next: create your stack repo from miuops-stack-template"
    fi
}

cmd_add_domain() {
    local host="" doms=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)  DRY_RUN=true; shift ;;
            --no-apply) NO_APPLY=true; shift ;;
            -*) die "Unknown flag: $1" ;;
            *)  if [[ -z "$host" ]]; then host="$1"; else doms+=("$1"); fi; shift ;;
        esac
    done
    [[ -n "$host" && ${#doms[@]} -ge 1 ]] || die "Usage: miuops add-domain [--dry-run] <host> <domain...>"
    valid_host_alias "$host" || die "Invalid host '${host}'"
    local _vd; for _vd in "${doms[@]}"; do valid_domain "$_vd" || die "Invalid domain: '${_vd}'"; done
    [[ -f "$(hv_path "$host")" ]] || die "No host_vars for '${host}' — is it in inventory? Run 'miuops up' first."
    [[ -n "${CF_API_TOKEN:-}" ]] || die "CF_API_TOKEN is required"

    local tid; tid="$(hv_tunnel "$host")"
    [[ -n "$tid" ]] || die "host_vars/${host}.yml has no tunnel_id"

    local current=() d
    while IFS= read -r d; do [[ -n "$d" ]] && current+=("$d"); done < <(hv_domains "$host")

    local added=false dd owner present c zid
    for dd in "${doms[@]}"; do
        owner="$(domain_owner "$dd")"
        [[ -n "$owner" && "$owner" != "$host" ]] && die "Domain '${dd}' already belongs to '${owner}'."
        present=false
        for c in "${current[@]:-}"; do [[ "$c" == "$dd" ]] && present=true; done
        if $present; then info "${dd} already on ${host} (skip)"; continue; fi
        zid="$(cf_zone_id "$dd")"
        cf_create_cname "$zid" "$dd" "$tid"
        cf_create_cname "$zid" "*.${dd}" "$tid"
        current+=("$dd"); added=true
    done

    $added || { info "Nothing new to add."; return 0; }
    if $DRY_RUN; then dry "Would set ${host} domains: ${current[*]}"
    else write_host_vars "$host" "$tid" "${current[@]}"; fi
    run_apply "$host"
}

cmd_remove_domain() {
    local host="" doms=() force=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)  DRY_RUN=true; shift ;;
            --no-apply) NO_APPLY=true; shift ;;
            --force)    force=true; shift ;;
            -*) die "Unknown flag: $1" ;;
            *)  if [[ -z "$host" ]]; then host="$1"; else doms+=("$1"); fi; shift ;;
        esac
    done
    [[ -n "$host" && ${#doms[@]} -ge 1 ]] || die "Usage: miuops remove-domain [--dry-run] [--force] <host> <domain...>"
    valid_host_alias "$host" || die "Invalid host '${host}'"
    [[ -f "$(hv_path "$host")" ]] || die "No host_vars for '${host}'."
    [[ -n "${CF_API_TOKEN:-}" ]] || die "CF_API_TOKEN is required"

    local tid; tid="$(hv_tunnel "$host")"
    local keep=() d removed=false dd drop zid
    while IFS= read -r d; do
        [[ -z "$d" ]] && continue
        drop=false
        for dd in "${doms[@]}"; do [[ "$dd" == "$d" ]] && drop=true; done
        if $drop; then
            zid="$(cf_zone_id "$d")"
            cf_delete_cname "$zid" "$d"
            cf_delete_cname "$zid" "*.${d}"
            removed=true
        else
            keep+=("$d")
        fi
    done < <(hv_domains "$host")

    $removed || { warn "None of the given domains were on ${host} — nothing removed."; return 0; }
    if [[ ${#keep[@]} -eq 0 && "$force" != true ]]; then
        die "Refusing to remove the last domain of '${host}' (a server needs at least one). Use --force to override."
    fi
    if $DRY_RUN; then
        dry "Would set ${host} domains: ${keep[*]:-(none)}"
        return 0
    fi
    if [[ ${#keep[@]} -eq 0 ]]; then
        write_host_vars "$host" "$tid"
        warn "${host} now has no domains — skipping converge. Add a domain or remove the host."
        return 0
    fi
    write_host_vars "$host" "$tid" "${keep[@]}"
    run_apply "$host"
}

# ── Main ───────────────────────────────────────────────────────────
if [[ "${1:-}" != "--source-only" ]]; then
    case "${1:-}" in
        up)            shift; cmd_up "$@" ;;
        apply)         shift; cmd_apply "$@" ;;
        add-domain)    shift; cmd_add_domain "$@" ;;
        remove-domain) shift; cmd_remove_domain "$@" ;;
        *)             usage ;;
    esac
fi
